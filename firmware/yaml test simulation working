esphome:
  name: esphome-web-1b83dc
  friendly_name: irraBRANT
  min_version: 2025.11.0
  name_add_mac_suffix: false

esp32:
  variant: esp32c6
  framework:
    type: esp-idf

# Enable logging
logger:

# Enable Home Assistant API
api:

# Allow Over-The-Air updates
ota:
- platform: esphome

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

captive_portal:

# Simulação das 9 Zonas usando Template Switches
switch:
  - platform: template
    id: zone_1
    name: "Relé Físico 1"
    optimistic: true
  - platform: template
    id: zone_2
    name: "Relé Físico 2"
    optimistic: true
  - platform: template
    id: zone_3
    name: "Relé Físico 3"
    optimistic: true
  - platform: template
    id: zone_4
    name: "Relé Físico 4"
    optimistic: true
  - platform: template
    id: zone_5
    name: "Relé Físico 5"
    optimistic: true
  - platform: template
    id: zone_6
    name: "Relé Físico 6"
    optimistic: true
  - platform: template
    id: zone_7
    name: "Relé Físico 7"
    optimistic: true
  - platform: template
    id: zone_8
    name: "Relé Físico 8"
    optimistic: true
  - platform: template
    id: zone_9
    name: "Relé Físico 9"
    optimistic: true

# Lógica do Controlador de Irrigação com a sintaxe correta
sprinkler:
  - id: irribrant_ctrl
    main_switch: "irriBRANT Principal"
    auto_advance_switch: "Avanço Automático"
    valves:
      - valve_switch: "Válvula 1"
        valve_switch_id: zone_1
        run_duration: 1min
      - valve_switch: "Válvula 2"
        valve_switch_id: zone_2
        run_duration: 1min
      - valve_switch: "Válvula 3"
        valve_switch_id: zone_3
        run_duration: 1min
      - valve_switch: "Válvula 4"
        valve_switch_id: zone_4
        run_duration: 1min
      - valve_switch: "Válvula 5"
        valve_switch_id: zone_5
        run_duration: 1min
      - valve_switch: "Válvula 6"
        valve_switch_id: zone_6
        run_duration: 1min
      - valve_switch: "Válvula 7"
        valve_switch_id: zone_7
        run_duration: 1min
      - valve_switch: "Válvula 8"
        valve_switch_id: zone_8
        run_duration: 1min
      - valve_switch: "Válvula 9"
        valve_switch_id: zone_9
        run_duration: 1min
